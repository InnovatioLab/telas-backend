<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <title>Telas monitoring</title>
</head>
<body style="font-family: Montserrat, Arial, sans-serif; font-size: 16px; color: #111519;">
<p><strong>Box status updated</strong></p>
<p>Box IP: ${ip}</p>
<p>Status: ${statusLabel}</p>
<p>Linked monitors: ${monitorAddresses}</p>
<p>Incident: ${incidentType} ${severity}</p>
<p>Time: ${notifiedAt}</p>
</body>
</html>
